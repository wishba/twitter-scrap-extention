{
  "manifest_version": 3,
  "name": "Tweet Scraper",
  "version": "1.0.0",
  "description": "Detect and download tweets from the current Twitter/X page.",

  "permissions": [
    "activeTab",
    "downloads",
    "storage"
  ],

  "host_permissions": [
    "*://twitter.com/*",
    "*://x.com/*"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": [
        "*://twitter.com/*",
        "*://x.com/*"
      ],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Tweet Scraper",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "96": "icons/icon96.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "tweet-scraper@local",
      "strict_min_version": "109.0"
    }
  }
}
